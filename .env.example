POSTGRES_DB=agenticqueue
POSTGRES_USER=agenticqueue
POSTGRES_PASSWORD=agenticqueue

AGENTICQUEUE_API_PORT=8000
AGENTICQUEUE_WEB_PORT=3000
AGENTICQUEUE_DB_PORT=5432
AGENTICQUEUE_PGBOUNCER_PORT=64329

AGENTICQUEUE_DATABASE_URL=postgresql+asyncpg://agenticqueue:agenticqueue@127.0.0.1:64329/agenticqueue
AGENTICQUEUE_TOKEN_SIGNING_SECRET=agenticqueue-dev-token-signing-secret
# CHANGE THIS BEFORE FIRST BOOT. Missing/empty AQ_ADMIN_PASSCODE fails the server closed when no users exist.
AQ_ADMIN_PASSCODE=change-this-before-first-boot
AGENTICQUEUE_API_BASE_URL=http://127.0.0.1:8000
