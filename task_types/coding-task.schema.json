{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "coding-task",
  "type": "object",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": "object",
      "required": [
        "kind",
        "uri"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "uri": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "details": {
          "type": "object",
          "default": {}
        }
      },
      "additionalProperties": false
    },
    "dodVerificationMethod": {
      "enum": [
        "test",
        "command",
        "code_inspection",
        "artifact",
        "reviewer_check"
      ]
    },
    "dodItem": {
      "type": "object",
      "required": [
        "id",
        "statement",
        "verification_method",
        "evidence_required",
        "acceptance_threshold"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "statement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verification_method": {
          "$ref": "#/$defs/dodVerificationMethod"
        },
        "evidence_required": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "acceptance_threshold": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "learning": {
      "type": "object",
      "required": [
        "title",
        "type",
        "what_happened",
        "what_learned",
        "action_rule",
        "applies_when",
        "does_not_apply_when",
        "evidence",
        "scope",
        "confidence",
        "status",
        "owner",
        "review_date"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "type": {
          "enum": [
            "pitfall",
            "pattern",
            "decision-followup",
            "tooling",
            "repo-behavior",
            "user-preference",
            "process-rule"
          ]
        },
        "what_happened": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "what_learned": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "action_rule": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "applies_when": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "does_not_apply_when": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "minItems": 1
        },
        "scope": {
          "enum": [
            "task",
            "project",
            "global"
          ]
        },
        "confidence": {
          "enum": [
            "tentative",
            "confirmed",
            "validated"
          ]
        },
        "status": {
          "enum": [
            "active",
            "superseded",
            "expired"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "review_date": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "repo",
    "branch",
    "file_scope",
    "surface_area",
    "spec",
    "dod_checklist",
    "autonomy_tier",
    "output"
  ],
  "properties": {
    "repo": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "branch": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "file_scope": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1
    },
    "surface_area": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1
    },
    "spec": {
      "type": "string",
      "minLength": 1,
      "contentMediaType": "text/markdown"
    },
    "dod_checklist": {
      "description": "Compatibility projection of the human-readable DoD statements persisted to task.definition_of_done until the structured proof path fully takes over.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1
    },
    "dod_items": {
      "description": "Structured DoD proof items backing ADR-AQ-030. When present, these are the canonical proof records and dod_checklist remains the compatibility projection.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/dodItem"
      },
      "minItems": 1
    },
    "dod_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item",
          "type"
        ],
        "properties": {
          "item": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "type": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "path": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "path_mode": {
            "enum": [
              "exact",
              "glob",
              "regex"
            ]
          },
          "pattern": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "schema_name": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "min_count": {
            "type": "integer",
            "minimum": 0
          },
          "min_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "max_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "repo": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "sha": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "check_name": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "pr_number": {
            "type": "integer",
            "minimum": 1
          },
          "timeout_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "autonomy_tier": {
      "type": "integer",
      "enum": [
        1,
        2,
        3,
        4,
        5
      ]
    },
    "output": {
      "type": "object",
      "required": [
        "diff_url",
        "test_report",
        "artifacts",
        "learnings"
      ],
      "properties": {
        "diff_url": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "test_report": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          },
          "minItems": 1
        },
        "learnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/learning"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
